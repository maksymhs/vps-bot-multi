# Generated by vps-bot-multi installer
# Multi-user AI deploy platform

# ━━━ Network Configuration ━━━
# Choose ONE of the following:

# Option 1: Custom Domain (with Caddy + auto SSL)
# Apps: https://u{userId}-{app}.your-domain.com
DOMAIN=your-domain.com

# Option 2: IP Address + Port (no SSL)
# IP_ADDRESS=192.168.1.100
# PORT=8080

# ━━━ Storage ━━━
PROJECTS_DIR=/home/vpsbot/projects

# ━━━ Claude Code CLI (REQUIRED) ━━━
CLAUDE_CLI=/usr/local/bin/claude
NODE_BIN=/usr/bin/node

# ━━━ Telegram Bot (REQUIRED) ━━━
BOT_TOKEN=your_telegram_bot_token

# ━━━ Admin ━━━
# Your Telegram user ID — gets access to server status & user management
ADMIN_USER_ID=123456789

# ━━━ Multi-user Limits ━━━
# Max number of apps each user can create
MAX_APPS_PER_USER=3

# ━━━ Auto-sleep ━━━
# Stop idle containers after N minutes (default: 30)
IDLE_TIMEOUT=30

# ━━━ OpenRouter API (OPTIONAL) ━━━
# For using alternative LLM models
# OPENROUTER_API_KEY=

# ━━━ Templates ━━━
# Public repo with app templates for faster builds
# TEMPLATES_REPO=https://github.com/maksymhs/vps-bot-templates.git
# TEMPLATES_DIR=/root/vps-bot-templates

# ━━━ System Configuration ━━━
CADDY_ADMIN_URL=http://localhost:2019
DOCKER_SOCKET=/var/run/docker.sock
