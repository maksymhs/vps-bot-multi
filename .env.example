# Generated by VPS-CODE-BOT installer
# Edit manually or run: npm run setup

# ━━━ Network Configuration ━━━
# Choose ONE of the following:

# Option 1: Custom Domain (with Caddy + auto SSL)
# Apps: https://{app}.your-domain.com
# Code: https://code.your-domain.com
DOMAIN=your-domain.com

# Option 2: IP Address + Port (no SSL)
# IP_ADDRESS=192.168.1.100
# PORT=8080

# ━━━ Storage ━━━
PROJECTS_DIR=/home/your_user/vps-code-bot-projects

# ━━━ Claude Code CLI (REQUIRED) ━━━
CLAUDE_CLI=/path/to/claude-code/cli.js
NODE_BIN=/usr/bin/node

# ━━━ Code-Server ━━━
# Domain mode: accessible via https://code.{DOMAIN} (Caddy proxies)
# IP mode: accessible via http://{IP}:{CODE_SERVER_PORT}
CODE_SERVER_PASSWORD=your_password
CODE_SERVER_PORT=8080

# ━━━ Telegram Bot (OPTIONAL) ━━━
# Leave empty to skip Telegram integration
# BOT_TOKEN=your_telegram_bot_token
# CHAT_ID=your_chat_id

# ━━━ OpenRouter API (OPTIONAL) ━━━
# For using alternative LLM models
# OPENROUTER_API_KEY=

# ━━━ Templates ━━━
# Public repo with app templates for faster builds
# TEMPLATES_REPO=https://github.com/maksymhs/vps-bot-templates.git
# TEMPLATES_DIR=/root/vps-bot-templates

# ━━━ Auto-sleep ━━━
# Stop idle containers after N minutes (0 = disabled)
# IDLE_TIMEOUT=10

# ━━━ System Configuration ━━━
CADDY_ADMIN_URL=http://localhost:2019
DOCKER_SOCKET=/var/run/docker.sock
